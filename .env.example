# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/radio_store?schema=public"

# Auth
AUTH_SECRET="change-me-to-a-long-random-string-in-production"
NEXTAUTH_URL="http://localhost:3000"

# PayPal — to GO LIVE, paste the credentials from your PayPal app here and
# restart the container (docker compose ... up -d). No rebuild is required.
# All three values below must come from the SAME PayPal app and the SAME mode.
#   - PAYPAL_CLIENT_ID / PAYPAL_CLIENT_SECRET: server-side REST API credentials (keep secret)
#   - NEXT_PUBLIC_PAYPAL_CLIENT_ID: the same Client ID, exposed to the browser SDK
#   - PAYPAL_MODE: "live" for real payments, "sandbox" for testing
# Verify status anytime in Admin > Settings > Payments.
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-client-secret"
PAYPAL_MODE="sandbox"
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-client-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Hytera Radios"

# Admin seed credentials (used by prisma seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# SMTP (OTP signup verification emails)
# Leave SMTP_HOST empty to fall back to logging the OTP to the server console.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-sender@gmail.com"
SMTP_PASS="your-16-char-app-password"
SMTP_FROM="Hytera Radios <your-sender@gmail.com>"

# Public testing (Cloudflare + PayPal sandbox) — ready-to-run config in .env.public
# Deploy: ./deploy-public.sh
# Or:     docker compose --env-file .env.public -f docker-compose.public.yml up -d --build
#
# AUTH_SECRET=c8f4a2e91b7d463089e1f5a2c4b6d8e0f3a5c7b9d1e3f5a7c9b1d3e5f7a9c1b3
# NEXTAUTH_URL=https://hyteraradios.ca
# NEXT_PUBLIC_APP_URL=https://hyteraradios.ca
# PAYPAL_MODE=sandbox
# (see .env.public for full values)

# ---------------------------------------------------------------------------
# Production with Caddy (own TLS cert, no Cloudflare proxy)
# ---------------------------------------------------------------------------
# DOMAIN=yourdomain.com
# POSTGRES_PASSWORD=strong-password
# PAYPAL_MODE=live
# Deploy: docker compose -f docker-compose.prod.yml up -d --build
