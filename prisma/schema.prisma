generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum ProductStatus {
  ACTIVE
  DRAFT
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum Currency {
  CAD
  USD
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
  REFUNDED
  FAILED
}

enum RefundType {
  FULL
  PARTIAL
}

enum RefundStatus {
  PROCESSED
  PENDING
  FAILED
}

enum ExpensePaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
}

enum InventoryChangeType {
  SALE
  MANUAL_ADJUSTMENT
  RESTOCK
  RETURN
  DELETED_VARIANT
}

enum QuoteSubmissionType {
  QUOTE
  PREORDER
  STAY_CONNECTED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(CUSTOMER)
  avatarUrl    String?
  phone        String?
  addressLine1   String?
  addressLine2   String?
  addressCity    String?
  addressState   String?
  addressPostal  String?
  addressCountry String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cart               Cart?
  orders             Order[]
  auditLogs          AuditLog[]
  expenses           Expense[]
  refundsProcessed   Refund[]            @relation("RefundProcessedBy")
  inventoryChanges   InventoryMovement[] @relation("InventoryChangedBy")
  passwordResetTokens PasswordResetToken[]
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products ProductCategory[]
}

model Industry {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products ProductIndustry[]
}

model Series {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
}

model SignalType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  products ProductSignalType[]
}

model FrequencyBand {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  products ProductFrequencyBand[]
}

model Product {
  id                   String        @id @default(cuid())
  name                 String
  slug                 String        @unique
  brand                String?
  description          String        @db.Text
  shortDescription     String?
  specifications       String?       @db.Text
  images               String[]
  status               ProductStatus @default(DRAFT)
  isNewArrival         Boolean       @default(false)
  isBestSeller         Boolean       @default(false)
  priceCadCents        Int
  priceUsdCents        Int
  saleCadCents         Int?
  saleUsdCents         Int?
  hasVariants          Boolean       @default(false)
  stock                Int           @default(0)
  purchaseCostCents    Int?
  lowStockThreshold    Int           @default(5)
  seriesId             String?
  frequencyOptions     String[]      @default([])
  allowCustomFrequency Boolean       @default(false)
  customTxRequired     Boolean       @default(false)
  customRxRequired     Boolean       @default(false)
  shippingEnabled      Boolean       @default(true)
  lengthCm             Float?
  widthCm              Float?
  heightCm             Float?
  weightGrams          Int?
  shippingClassId      String?
  youtubeUrl           String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  series              Series?                @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  options             ProductOption[]
  variants            ProductVariant[]
  categories          ProductCategory[]
  industries          ProductIndustry[]
  cartItems           CartItem[]
  orderItems          OrderItem[]
  reviews             Review[]
  signalTypes         ProductSignalType[]
  frequencyBands      ProductFrequencyBand[]
  relatedFrom         RelatedProduct[]       @relation("ProductRelatedFrom")
  relatedTo           RelatedProduct[]       @relation("ProductRelatedTo")
  compatibleFrom      CompatibleProduct[]    @relation("ProductCompatibleFrom")
  compatibleTo        CompatibleProduct[]    @relation("ProductCompatibleTo")
  inventoryMovements  InventoryMovement[]
  shippingClass       ShippingClass?         @relation(fields: [shippingClassId], references: [id], onDelete: SetNull)
  heroFeatured        HeroFeaturedProduct?
}

model RelatedProduct {
  id               String @id @default(cuid())
  productId        String
  relatedProductId String
  position         Int    @default(0)

  product        Product @relation("ProductRelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductRelatedTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@index([productId])
}

model CompatibleProduct {
  id                   String @id @default(cuid())
  productId            String
  compatibleProductId  String
  position             Int    @default(0)

  product            Product @relation("ProductCompatibleFrom", fields: [productId], references: [id], onDelete: Cascade)
  compatibleProduct  Product @relation("ProductCompatibleTo", fields: [compatibleProductId], references: [id], onDelete: Cascade)

  @@unique([productId, compatibleProductId])
  @@index([productId])
}

model ProductSignalType {
  productId    String
  signalTypeId String

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  signalType SignalType @relation(fields: [signalTypeId], references: [id], onDelete: Cascade)

  @@id([productId, signalTypeId])
}

model ProductFrequencyBand {
  productId       String
  frequencyBandId String

  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  frequencyBand FrequencyBand @relation(fields: [frequencyBandId], references: [id], onDelete: Cascade)

  @@id([productId, frequencyBandId])
}

model ProductOption {
  id        String   @id @default(cuid())
  productId String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values  ProductOptionValue[]
}

model ProductOptionValue {
  id       String @id @default(cuid())
  optionId String
  value    String
  position Int    @default(0)

  option         ProductOption          @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantOptions ProductVariantOption[]
}

model ProductVariant {
  id            String  @id @default(cuid())
  productId     String
  sku           String  @unique
  stock         Int     @default(0)
  priceCadCents Int?
  priceUsdCents Int?
  saleCadCents  Int?
  saleUsdCents  Int?
  image         String?
  shippingEnabled Boolean @default(true)
  lengthCm      Float?
  widthCm       Float?
  heightCm      Float?
  weightGrams   Int?
  shippingClassId String?

  product       Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  shippingClass ShippingClass?         @relation(fields: [shippingClassId], references: [id], onDelete: SetNull)
  options    ProductVariantOption[]
  cartItems  CartItem[]
  orderItems OrderItem[]
}

model ProductVariantOption {
  id            String @id @default(cuid())
  variantId     String
  optionValueId String

  variant     ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionValueId])
}

model ProductCategory {
  productId  String
  categoryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
}

model ProductIndustry {
  productId  String
  industryId String

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  industry Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([productId, industryId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?  @unique
  guestId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id          String   @id @default(cuid())
  cartId      String
  productId   String
  variantId   String?
  quantity    Int      @default(1)
  txFrequency String   @default("")
  rxFrequency String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cart    Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@unique([cartId, productId, variantId, txFrequency, rxFrequency])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  guestEmail      String?
  status          OrderStatus @default(PENDING)
  currency        Currency
  subtotalCents   Int
  shippingCents   Int
  taxCents        Int         @default(0)
  taxLabel        String?
  taxRatePercent  Float?
  adjustmentCents Int         @default(0)
  shippingOverride Boolean    @default(false)
  taxOverride     Boolean     @default(false)
  totalCents      Int
  trackingNumber  String?
  paypalOrderId   String?
  paypalCaptureId String?
  shippingName    String
  shippingLine1   String
  shippingLine2   String?
  shippingCity    String
  shippingState   String
  shippingPostal  String
  shippingCountry String
  billingName     String?
  billingLine1    String?
  billingLine2    String?
  billingCity     String?
  billingState    String?
  billingPostal   String?
  billingCountry  String?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User?              @relation(fields: [userId], references: [id])
  items           OrderItem[]
  invoices        Invoice[]
  ledgerEntry     IncomeLedgerEntry?
  paymentRecords  PaymentRecord[]
  refunds         Refund[]
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  productId      String
  variantId      String?
  productName    String
  variantLabel   String?
  sku            String?
  quantity       Int
  unitPriceCents Int
  txFrequency       String?
  rxFrequency       String?
  selectedFrequency String?

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  productId String?
  author    String
  content   String   @db.Text
  rating    Int      @default(5)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model FeaturedItem {
  id        String   @id @default(cuid())
  title     String
  image     String?
  videoUrl  String?
  altText   String?
  linkUrl   String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HeroSlide {
  id        String   @id @default(cuid())
  title     String?
  subtitle  String?
  image     String
  linkUrl   String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([position])
}

model HeroFeaturedProduct {
  id        String   @id @default(cuid())
  productId String   @unique
  position  Int      @default(0)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([position])
}

model SiteSettings {
  id                    String   @id @default("singleton")
  dualCurrencyEnabled   Boolean  @default(true)
  taxLabel              String   @default("HST")
  taxRatePercent        Float    @default(13)
  companyName           String   @default("WirelessCom")
  quoteRecipients       String   @default("abu@wirelesscom.ca, service@wirelesscom.ca")
  smtpHost              String?
  smtpPort              Int?
  smtpSecure            Boolean  @default(false)
  smtpUser              String?
  smtpPasswordEnc       String?
  smtpFrom              String?
  sessionTimeoutMinutes Int      @default(30)
  announcementText      String   @default("Free shipping available on eligible products and orders.")
  announcementEnabled   Boolean  @default(true)
  proudlyCanadianEnabled Boolean @default(true)
  siteLogoUrl           String?
  siteFaviconUrl        String?
  updatedAt             DateTime @updatedAt
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ip        String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([email, ip, createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorId       String?
  actorEmail    String
  action        String
  entityType    String
  entityId      String?
  summary       String
  metadata      Json?
  ipAddress     String?
  previousValue Json?
  newValue      Json?
  createdAt     DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([createdAt])
  @@index([action])
}

model InvoiceSettings {
  id                 String   @id @default("singleton")
  logoPath           String?
  companyName        String   @default("WirelessCom.Ca Inc.")
  companyAddress     String   @default("97 White Oak Drive East\nSault Ste. Marie, ON P6B 4J7")
  taxNumber          String?
  phone              String?
  email              String?
  footerMessage      String   @default("Thank you for your business!")
  returnPolicy       String   @default("Returns accepted within 30 days of purchase.")
  invoicePrefix      String   @default("INV-")
  nextInvoiceNumber  Int      @default(1001)
  updatedAt          DateTime @updatedAt
}

model Invoice {
  id            String   @id @default(cuid())
  orderId       String
  invoiceNumber String   @unique
  pdfPath       String
  version       Int      @default(1)
  archivedPaths Json?
  generatedAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model TaxRule {
  id         String   @id @default(cuid())
  country    String
  province   String?
  label      String
  rate       Float
  isDefault  Boolean  @default(false)
  isEnabled  Boolean  @default(true)
  stackGroup String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([country, province])
}

model ShippingRegion {
  id                   String   @id @default(cuid())
  country              String   @unique
  freeShippingEnabled  Boolean  @default(true)
  thresholdCents       Int      @default(12500)
  flatRateCents        Int      @default(1500)
  displayMessage       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model IncomeLedgerEntry {
  id              String   @id @default(cuid())
  orderId         String   @unique
  orderDate       DateTime
  customerName    String
  revenueAmount   Int
  shippingIncome  Int
  taxCollected    Int
  discountAmount  Int      @default(0)
  netRevenue      Int
  paymentMethod   String?
  transactionId   String?
  createdAt       DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderDate])
}

model ExpenseCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  expenses  Expense[]
}

model Expense {
  id             String               @id @default(cuid())
  expenseDate    DateTime
  categoryId     String
  description    String               @db.Text
  amountCents    Int
  attachmentPath String?
  paymentStatus  ExpensePaymentStatus @default(PAID)
  createdById    String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  category  ExpenseCategory @relation(fields: [categoryId], references: [id])
  createdBy User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([expenseDate])
  @@index([categoryId])
}

model PaymentRecord {
  id                   String        @id @default(cuid())
  orderId              String
  paymentDate          DateTime      @default(now())
  customerName         String
  method               String
  transactionReference String?
  amountPaidCents      Int
  status               PaymentStatus @default(PENDING)
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([paymentDate])
  @@index([status])
}

model Refund {
  id                   String       @id @default(cuid())
  orderId              String
  customerName         String
  refundDate           DateTime     @default(now())
  amountCents          Int
  type                 RefundType
  reason               String?      @db.Text
  status               RefundStatus @default(PROCESSED)
  transactionReference String?
  processedById        String?
  createdAt            DateTime     @default(now())

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  processedBy User? @relation("RefundProcessedBy", fields: [processedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([refundDate])
}

model InventoryMovement {
  id          String              @id @default(cuid())
  productId   String
  variantId   String?
  productName String
  sku         String?
  changeType  InventoryChangeType
  qtyBefore   Int
  qtyAfter    Int
  delta       Int
  changedById String?
  changedAt   DateTime            @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  changedBy User?   @relation("InventoryChangedBy", fields: [changedById], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([changedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model QuoteSubmission {
  id              String              @id @default(cuid())
  type            QuoteSubmissionType
  name            String
  email           String
  phone           String?
  productInterest String?
  quantity        String?
  notes           String?             @db.Text
  createdAt       DateTime            @default(now())

  @@index([type])
  @@index([createdAt])
}

model ShippingClass {
  id              String   @id @default(cuid())
  name            String   @unique
  description     String?
  surchargeCents  Int      @default(0)
  createdAt       DateTime @default(now())

  products Product[]
  variants ProductVariant[]
}

model ShippingZone {
  id               String   @id @default(cuid())
  name             String
  country          String   @default("CA")
  provinces        String[] @default([])
  baseCostCents    Int      @default(1500)
  costPerKgCents   Int      @default(0)
  freeThresholdCents Int?
  isEnabled        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([country])
}

model PendingRegistration {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  otpHash      String
  expiresAt    DateTime
  attempts     Int      @default(0)
  lastSentAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
